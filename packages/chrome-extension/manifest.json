{
  "manifest_version": 3,
  "name": "Agents In Browser",
  "version": "0.1.0",
  "description": "AI-powered browser automation assistant. Control web pages with natural language.",
  "permissions": [
    "sidePanel",
    "tabs",
    "tabGroups",
    "activeTab",
    "scripting",
    "notifications",
    "alarms",
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Agents In Browser"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "quote-to-chat": {
      "suggested_key": {
        "default": "Ctrl+L",
        "mac": "Command+L"
      },
      "description": "Quote selection to chat"
    }
  }
}
